# Required: RTSP camera stream URL
RTSP_STREAM=rtsp://username:password@camera-ip:554/stream

# Optional: fixed trigger times (24h HH:MM)
# Leave empty if you only use INTERVAL
TIME_1=
TIME_2=
TIME_3=

# Optional: trigger every N minutes
# Leave empty if you only use TIME_1/2/3
INTERVAL=15

# Output directories (only alter if you know what you are doing)
SNAPSHOT_DIR_OUT=./snapshots
TIMELAPSE_DIR_OUT=./timelapse

# Desired timelapse duration in seconds
TIMELAPSE_LENGTH_SECONDS=10
